# TalentScout AI - Environment Variables
# Copy this file to .env.local and fill in your keys:
#   cp .env.example .env.local

# Required: At least one AI provider
# Get free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Fallback AI provider
# Get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Recommended: GitHub Personal Access Token (5000 req/hr vs 60 without)
# Create at https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=your_github_token_here
